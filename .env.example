# Required: Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required: Worxstream API (or set via POST /api/auth/session after login)
WORXSTREAM_BASE_URL=
WORXSTREAM_API_TOKEN=
DEFAULT_COMPANY_ID=
DEFAULT_USER_ID=

# Required: Server
PORT=3000
NODE_ENV=development

# Required: Database
MONGODB_URL=

# Required in production: public URL of this API and allowed CORS origins
BACKEND_URL=
CORS_ORIGINS=

# Optional: use PUBLIC_URL instead of BACKEND_URL
# PUBLIC_URL=

# Optional: context window limits
MAX_CONTEXT_MESSAGES=50
MAX_CONTEXT_TOKENS=150000
RESERVE_TOKENS=10000

# Optional: force tool search on/off (auto-detected by model if unset)
# ANTHROPIC_USE_TOOL_SEARCH=true
